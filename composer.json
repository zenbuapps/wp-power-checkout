{
	"name": "j7-dev/power-checkout",
	"description": "串接金流、物流、電子發票，全面優化 WooCommerce 購物車、結帳頁、我的帳號等頁面，讓結帳轉換率一飛沖天",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-only",
	"authors": [
		{
			"name": "JerryLiu",
			"email": "j7.dev.gg@gmail.com",
			"homepage": "https://github.com/j7-dev",
			"role": "Developer"
		}
	],
	"autoload": {
		"psr-4": {
			"J7\\PowerCheckout\\": "inc/classes/",
			"J7\\PowerCheckoutTests\\": "inc/tests/"
		}
	},
	"extra": {
		"mozart": {
			"dep_namespace": "PowerCheckout\\",
			"dep_directory": "/vendor_prefixed/",
			"classmap_directory": "/vendor_prefixed/classes/",
			"classmap_prefix": "PowerCheckout_",
			"packages": [
				"j7-dev/wp-utils",
				"psr/log"
			]
		}
	},
	"require": {
		"j7-dev/wp-utils": "^0.3",
		"giggsey/libphonenumber-for-php-lite": "^9.0"
	},
	"require-dev": {
		"dealerdirect/phpcodesniffer-composer-installer": "@stable",
		"php-stubs/woocommerce-stubs": "@stable",
		"php-stubs/wordpress-stubs": "@stable",
		"phpcompatibility/php-compatibility": "@stable",
		"phpstan/extension-installer": "@stable",
		"phpstan/phpstan": "@stable",
		"phpunit/phpunit": "^9.0",
		"roave/security-advisories": "dev-latest",
		"squizlabs/php_codesniffer": "@stable",
		"wp-coding-standards/wpcs": "@stable",
		"wp-phpunit/wp-phpunit": "^6.0",
		"yoast/phpunit-polyfills": "^4.0"
	},
	"config": {
		"platform": {
			"php": "8.2"
		},
		"sort-packages": true,
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true,
			"phpstan/extension-installer": true,
			"roots/wordpress-core-installer": true,
			"pestphp/pest-plugin": true
		}
	},
	"scripts": {
		"lint": "phpcs",
		"test": "set API_MODE=mock && vendor\\bin\\phpunit --colors=always --testdox --verbose",
		"test:mock": "set API_MODE=mock && vendor\\bin\\phpunit --colors=always --testdox --verbose",
		"test:sandbox": "set API_MODE=sandbox && vendor\\bin\\phpunit --colors=always --testdox --verbose",
		"test:prod": "set API_MODE=prod && vendor\\bin\\phpunit --colors=always --testdox --verbose",
		"test:debug": "set DEBUG=true && vendor\\bin\\phpunit --colors=always --testdox --verbose",
		"test:coverage": "vendor\\bin\\phpunit --coverage",
		"test:warning": "vendor\\bin\\phpunit --display-warnings"
	}
}
